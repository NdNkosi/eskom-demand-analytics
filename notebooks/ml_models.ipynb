  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "aadbec98",
   "metadata": {},
   "outputs": [],
   "source": [
    "features = [\n",
    "    'hour', 'day', 'month', 'day_of_week', 'week',\n",
    "    'forecast_demand', 'stress_index', 'import_ratio',\n",
    "    'lag_1h', 'lag_24h', 'lag_168h'\n",
    "]\n",
    "\n",
    "X = df[features]\n",
    "y = df['actual_demand']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "5dd579c1",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.model_selection import train_test_split"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "ec0be66b",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=0.2, shuffle=False\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "8382c3c5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Training rows: 33792\n",
      "Testing rows:  8448\n"
     ]
    }
   ],
   "source": [
    "print(f\"Training rows: {len(X_train)}\")\n",
    "print(f\"Testing rows:  {len(X_test)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "86a54337",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.linear_model import LinearRegression\n",
    "from sklearn.metrics import mean_absolute_error, mean_squared_error\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "89828599",
   "metadata": {},
   "outputs": [],
   "source": [
    "lr = LinearRegression()\n",
    "lr.fit(X_train, y_train)\n",
    "y_pred_lr = lr.predict(X_test)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "a73d3469",
   "metadata": {},
   "outputs": [],
   "source": [
    "mae_lr  = mean_absolute_error(y_test, y_pred_lr)\n",
    "rmse_lr = np.sqrt(mean_squared_error(y_test, y_pred_lr))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "7782283e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Linear Regression MAE:  131.96 MW\n",
      "Linear Regression RMSE: 171.07 MW\n"
     ]
    }
   ],
   "source": [
    "print(f\"Linear Regression MAE:  {mae_lr:.2f} MW\")\n",
    "print(f\"Linear Regression RMSE: {rmse_lr:.2f} MW\")"
   ]
  },
  {
