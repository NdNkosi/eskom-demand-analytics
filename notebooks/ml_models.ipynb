   "metadata": {},
   "outputs": [],
   "source": [
    "df['datetime'] = pd.to_datetime(df['datetime'])\n",
    "df = df.sort_values('datetime')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "ee9a75e6",
   "metadata": {},
   "outputs": [],
   "source": [
    "df['hour']        = df['datetime'].dt.hour\n",
    "df['day']         = df['datetime'].dt.day\n",
    "df['month']       = df['datetime'].dt.month\n",
    "df['day_of_week'] = df['datetime'].dt.dayofweek\n",
    "df['week']        = df['datetime'].dt.isocalendar().week.astype(int)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "977ec59e",
   "metadata": {},
   "outputs": [],
   "source": [
    "df['stress_index']  = df['actual_demand'] / df['capacity']\n",
    "df['forecast_error'] = df['actual_demand'] - df['forecast_demand']\n",
    "df['import_ratio']  = df['imports'] / df['actual_demand']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "afb7372a",
   "metadata": {},
   "outputs": [],
   "source": [
    "df['lag_1h']  = df['actual_demand'].shift(1)\n",
    "df['lag_24h'] = df['actual_demand'].shift(24)\n",
    "df['lag_168h'] = df['actual_demand'].shift(168)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "d33dd947",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
