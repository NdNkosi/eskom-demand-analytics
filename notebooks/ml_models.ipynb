      "(42240, 20)\n"
     ]
    }
   ],
   "source": [
    "df.dropna(inplace=True)\n",
    "print(df.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "d75f5606",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "Index(['datetime', 'forecast_demand', 'actual_demand', 'exports', 'imports',\n",
       "       'nuclear', 'pump_storage', 'capacity', 'hour', 'day', 'month', 'year',\n",
       "       'day_of_week', 'stress_index', 'forecast_error', 'import_ratio', 'week',\n",
       "       'lag_1h', 'lag_24h', 'lag_168h'],\n",
       "      dtype='str')"
      ]
     },
     "execution_count": 12,
     "metadata": {},
